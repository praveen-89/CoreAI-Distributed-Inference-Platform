# API Gateway Configuration
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
# Header validation key (clients must present this token)
COREAI_API_KEY=sk-coreai-development-key-2026

# Redis Connection Details
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=coreai_secure_pass
REDIS_DB=0

# Inference Worker Configurations
# Target model key. Must match directories/names in HF or local paths
MODEL_NAME=gpt-2
# Device placement: 'cpu' or 'cuda' (GPU)
DEVICE=cpu
# Queue polling timeout in seconds
WORKER_POLL_TIMEOUT=5

# Monitoring Configurations
PROMETHEUS_PORT=9090
METRICS_PORT=8001
